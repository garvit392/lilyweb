</section>

<!-- Footer -->
<footer class="border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-neutral-500">
    <div class="flex items-center gap-3">
      <img src="/lily.png" alt="Lily" class="w-7 h-7 rounded-full" />
      <span>© <span id="year">2026</span> lily</span>
    </div>
    <div class="flex flex-wrap gap-6">
      <a href="/commands" class="hover:text-white transition">Commands</a>
      <a href="/dashboard" class="hover:text-white transition">Dashboard</a>
      <a href="/terms" class="hover:text-white transition">Terms</a>
      <a href="/privacy" class="hover:text-white transition">Privacy</a>
      <a href="https://discord.gg/RYY9SU4uj" target="_blank" rel="noopener" class="hover:text-white transition">Support</a>
      <a href="https://discord.com/oauth2/authorize?client_id=1493552809415671830" target="_blank" rel="noopener" class="hover:text-white transition">Invite</a>
    </div>
  </div>
</footer>

<script>
  document.getElementById('year').textContent = new Date().getFullYear();

  // Animated counters
  const fmt = n => n.toLocaleString();
  const counters = document.querySelectorAll('[data-count]');
  const animate = (el, target) => {
    const start = performance.now();
    const dur = 1600;
    function tick(t) {
      const p = Math.min(1, (t - start) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = fmt(Math.floor(eased * target));
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  };
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        if (e.target.dataset.count) {
          animate(e.target, parseInt(e.target.dataset.count, 10));
          io.unobserve(e.target);
        } else {
          e.target.classList.add('in');
        }
      }
    });
  }, { threshold: 0.2 });
  counters.forEach(c => io.observe(c));
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // Live ticker — fetch real stats periodically and gently increment in between
  const liveTargets = [
    { id: 'stat-users',  base: 23694963, drift: () => Math.floor(Math.random()*9)+2 },
    { id: 'stat-guilds', base: 165898,   drift: () => (Math.random() < 0.55 ? 1 : 0) },
  ];
  const liveState = {};
  liveTargets.forEach(t => liveState[t.id] = t.base);

  function pulse(el){
    el.style.transition = 'color .25s ease, transform .25s ease';
    el.style.color = '#fbcfe8';
    el.style.transform = 'translateY(-2px)';
    setTimeout(() => { el.style.color = ''; el.style.transform = ''; }, 250);
  }

  async function refreshStats() {
    try {
      const r = await fetch('/api/stats', { cache: 'no-store' });
      if (!r.ok) return;
      const j = await r.json();
      if (typeof j.users === 'number') liveState['stat-users'] = j.users;
      if (typeof j.guilds === 'number') liveState['stat-guilds'] = j.guilds;
      if (typeof j.commands === 'number') {
        const ce = document.getElementById('stat-commands');
        if (ce) ce.textContent = fmt(j.commands);
      }
    } catch {}
  }

  // First show the animated reveal (handled by IO), then start ticking after it finishes
  setTimeout(() => {
    refreshStats();
    setInterval(refreshStats, 30_000);
    setInterval(() => {
      liveTargets.forEach(t => {
        const el = document.getElementById(t.id); if (!el) return;
        const inc = t.drift();
        if (!inc) return;
        liveState[t.id] += inc;
        el.textContent = fmt(liveState[t.id]);
        pulse(el);
      });
    }, 4000);
  }, 2200);
</script>
<!-- ===== Cookie / data consent ===== -->
<div id="lily-consent" class="fixed bottom-4 inset-x-4 md:inset-x-auto md:right-6 md:bottom-6 md:max-w-md z-[60] hidden">
  <div class="rounded-2xl border border-pink-500/30 bg-neutral-950/95 backdrop-blur-xl shadow-2xl shadow-pink-900/30 p-5">
    <div class="flex items-start gap-3">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-pink-500 to-purple-500 grid place-items-center text-lg shrink-0">🍪</div>
      <div class="flex-1 min-w-0">
        <h4 class="text-sm font-semibold text-white">Cookies &amp; data</h4>
        <p class="mt-1 text-xs text-neutral-400 leading-relaxed">
          We use one first-party session cookie (<code class="text-pink-300">lily.sid</code>) only when you sign in to the dashboard, and your dashboard preferences are stored in your browser's localStorage. No third-party tracking, ads, or analytics.
          See our <a href="/privacy" class="text-pink-400 underline">Privacy Policy</a>.
        </p>
        <div class="mt-3 flex items-center gap-2">
          <button id="lily-consent-accept" class="px-3 py-1.5 rounded-full text-xs font-semibold text-white" style="background:linear-gradient(90deg,#ec4899,#c084fc);">Accept</button>
          <button id="lily-consent-decline" class="px-3 py-1.5 rounded-full text-xs font-medium text-neutral-300 border border-white/10 hover:bg-white/5">Decline</button>
          <button id="lily-consent-close" aria-label="Close" class="ml-auto text-neutral-500 hover:text-white text-xl leading-none px-1">×</button>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
(function(){
  var KEY='lily.consent.v1';
  try { if(localStorage.getItem(KEY)) return; } catch(e){}
  var el=document.getElementById('lily-consent'); if(!el) return;
  setTimeout(function(){ el.classList.remove('hidden'); }, 400);
  function set(v){ try{ localStorage.setItem(KEY, JSON.stringify({choice:v,ts:Date.now()})); }catch(e){} el.remove(); }
  document.getElementById('lily-consent-accept').onclick=function(){ set('accepted'); };
  document.getElementById('lily-consent-decline').onclick=function(){
    try{ localStorage.removeItem('lily.dashboard.v1'); }catch(e){}
    set('declined');
  };
  document.getElementById('lily-consent-close').onclick=function(){ set('dismissed'); };
})();
</script>

</body>
</html>
