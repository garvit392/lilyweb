<!DOCTYPE html>
<html lang="en" class="dark">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lily — Discord's most powerful all-in-one app</title>
<meta name="description" content="Lily is Discord's most powerful all-in-one app for seamless server management, automation, and community engagement." />
<meta property="og:title" content="Lily" />
<meta property="og:description" content="Discord's most powerful all-in-one app for seamless server management, automation, and community engagement." />
<meta property="og:image" content="/lily.png" />
<link rel="icon" href="/lily.png" />
<script src="https://cdn.tailwindcss.com"></script>
<script>
tailwind.config = {
  darkMode: 'class',
  theme: { extend: {
    colors: {
      bg: '#0a0a0a',
      panel: '#111113',
      ring: '#1c1c20',
      lily: { 50:'#fdf2f8', 100:'#fce7f3', 200:'#fbcfe8', 300:'#f9a8d4', 400:'#f472b6', 500:'#ec4899', 600:'#db2777', 700:'#be185d', accent:'#c084fc' }
    },
    fontFamily: { sans: ['Inter','ui-sans-serif','system-ui'] }
  }}
};
</script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
<style>
  body { background: radial-gradient(1200px 600px at 50% -100px, rgba(236,72,153,.18), transparent 60%), #0a0a0a; }
  .glow { box-shadow: 0 0 40px rgba(236, 72, 153, .35); }
  .grad-text { background: linear-gradient(90deg,#f9a8d4 0%,#c084fc 50%,#60a5fa 100%); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .card { background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.01)); border: 1px solid rgba(255,255,255,.06); }
  .card:hover { border-color: rgba(236,72,153,.35); }
  .btn-primary { background: linear-gradient(90deg,#ec4899,#c084fc); }
  .btn-primary:hover { filter: brightness(1.1); }
  .nav-blur { backdrop-filter: blur(12px); background: rgba(10,10,10,.6); }
  .stat-num { background: linear-gradient(180deg,#fff,#a3a3a3); -webkit-background-clip: text; background-clip: text; color: transparent; }
  .marquee { animation: scroll 40s linear infinite; }
  @keyframes scroll { from { transform: translateX(0) } to { transform: translateX(-50%) } }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }
  .float { animation: float 4s ease-in-out infinite; }
  .reveal { opacity: 0; transform: translateY(16px); transition: all .8s cubic-bezier(.2,.7,.2,1); }
  .reveal.in { opacity: 1; transform: translateY(0); }
</style>
</head>
