    <div class="card rounded-2xl p-6 reveal">
      <div class="w-11 h-11 rounded-xl bg-lily-500/10 ring-1 ring-lily-500/30 flex items-center justify-center text-lily-400 mb-4">📜</div>
      <h3 class="font-semibold text-lg">Logs</h3>
