</section>

<!-- CTA -->
<section class="max-w-5xl mx-auto px-6 pb-24">
  <div class="card rounded-3xl p-10 md:p-14 text-center relative overflow-hidden">
    <div class="absolute -inset-1 bg-gradient-to-r from-lily-500/10 via-purple-500/10 to-blue-500/10 blur-2xl"></div>
    <div class="relative">
      <img src="/lily.png" alt="Lily" class="w-16 h-16 rounded-full mx-auto ring-2 ring-white/10" />
      <h3 class="mt-6 text-3xl md:text-4xl font-extrabold tracking-tight">Ready to upgrade your server?</h3>
      <p class="mt-3 text-neutral-400">Add Lily in seconds. Configure everything from a beautiful dashboard.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="https://discord.com/oauth2/authorize?client_id=1493552809415671830" target="_blank" rel="noopener"
           class="btn-primary px-6 py-3 rounded-full font-semibold glow">Add to Discord</a>
        <a href="/dashboard" class="px-6 py-3 rounded-full font-semibold border border-white/10 hover:bg-white/5 transition">Open Dashboard</a>
      </div>
